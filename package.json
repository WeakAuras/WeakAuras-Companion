{
  "name": "weakauras-companion",
  "version": "5.3.1",
  "description": "WeakAuras Companion App",
  "keywords": [
    "electron",
    "rollup",
    "vite",
    "vue3",
    "vue",
    "WeakAuras",
    "World of Warcraft"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/WeakAuras/WeakAuras-Companion.git"
  },
  "license": "GPL-2.0-or-later",
  "author": "Buds <mrbouyou@gmail.com>",
  "type": "module",
  "main": "dist-electron/main/index.mjs",
  "scripts": {
    "build": "vue-tsc && vp build && electron-builder",
    "clean": "git clean -xdf node_modules dist dist-electron",
    "compile-tools": "tsc -p tools",
    "dev": "vp dev",
    "i18n": "pnpm run compile-tools && node ./tools/scripts/extract-i18n-messages.js",
    "i18n-report": "pnpm dlx vue-i18n-extract report --add --remove --separator 'buggy' --vueFiles './src/**/*.?(ts|vue)' --languageFiles './i18n/*.json'",
    "preinstall": "npx only-allow pnpm",
    "lint": "vp lint ./src && vp fmt . --check",
    "lint:fix": "vp lint ./src --fix && vp fmt .",
    "prepare": "vp config",
    "test": "vp test run",
    "test:ui": "vp test --ui"
  },
  "config": {
    "default-locale": "en",
    "supported-locales": [
      "en",
      "es",
      "de",
      "fr",
      "ru",
      "tr",
      "zh-cn"
    ]
  },
  "dependencies": {
    "archiver": "7.0.1",
    "archiver-utils": "5.0.2",
    "got": "12.6.1",
    "regedit": "5.1.4",
    "sharp": "0.33.5",
    "tga": "1.0.7"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@iconify-json/fa6-brands": "1.2.5",
    "@iconify-json/mdi": "1.2.3",
    "@iconify/tools": "5.0.11",
    "@intlify/unplugin-vue-i18n": "11.0.7",
    "@types/archiver": "6.0.4",
    "@types/luaparse": "0.2.1",
    "@types/luxon": "3.7.1",
    "@types/node": "25.2.0",
    "@types/tail": "2.2.3",
    "@unocss/eslint-config": "66.6.6",
    "@unocss/preset-icons": "66.6.6",
    "@unocss/preset-web-fonts": "66.6.6",
    "@vitejs/plugin-vue": "6.0.5",
    "@vitest/ui": "4.0.3",
    "browserslist": "4.28.2",
    "electron": "41.1.1",
    "electron-builder": "26.8.1",
    "electron-log": "5.4.2",
    "electron-store": "11.0.2",
    "electron-updater": "6.6.2",
    "eslint-plugin-vue": "10.8.0",
    "floating-vue": "5.2.2",
    "glob": "13.0.1",
    "happy-dom": "20.8.9",
    "luaparse": "0.2.1",
    "luxon": "3.7.2",
    "pinia": "3.0.4",
    "pinia-plugin-persistedstate-2": "2.0.32",
    "playwright": "1.59.0",
    "tail": "2.2.6",
    "tree-kill": "1.2.2",
    "typescript": "5.8.3",
    "typescript-eslint": "8.58.0",
    "unocss": "66.6.6",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plugin-electron": "0.29.1",
    "vite-plugin-electron-renderer": "0.14.6",
    "vite-plugin-resolve": "2.5.2",
    "vite-plugin-vue-devtools": "8.1.1",
    "vite-plugin-webfont-dl": "3.12.0",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest",
    "vitest-browser-vue": "2.0.1",
    "vue": "3.5.32",
    "vue-i18n": "11.3.0",
    "vue-tsc": "3.2.6",
    "vite-plus": "latest"
  },
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=24"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild",
      "sharp",
      "vue-demi"
    ],
    "supportedArchitectures": {
      "cpu": [
        "x64",
        "arm64"
      ],
      "os": [
        "win32",
        "darwin",
        "linux"
      ]
    },
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    },
    "peerDependencyRules": {
      "allowAny": [
        "vite",
        "vitest"
      ],
      "allowedVersions": {
        "vite": "*",
        "vitest": "*"
      }
    }
  },
  "debug": {
    "env": {
      "VITE_DEV_SERVER_URL": "http://127.0.0.1:3344/"
    }
  }
}
